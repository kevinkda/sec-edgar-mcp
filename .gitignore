# ----------------------------------------------------------------------------
# sec-edgar-mcp project-specific entries
# ----------------------------------------------------------------------------

# Secrets / runtime artifacts (precise paths to avoid glob footguns).
# SEC EDGAR has NO authentication; the only env we keep secret is the
# operator's User-Agent contact email, which still belongs in .env not git.
.env
.env.*
!.env.example
.secrets.baseline.local

# Runtime state (must NEVER be committed; production data lives outside repo)
usage.jsonl
logs/

# CRITICAL: keep uv.lock in repository (reverse rule, avoid being swallowed
# by any earlier *.lock glob).
!uv.lock
