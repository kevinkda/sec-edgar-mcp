# ---------------------------------------------------------------------------
# sec-edgar-mcp environment template.
#
# The SEC EDGAR public API has NO authentication, but it DOES require every
# request to carry a descriptive User-Agent header in the form:
#
#     "App Name (contact@email.example)"
#
# See https://www.sec.gov/os/accessing-edgar-data — non-compliant requests
# can be rate-limited or blocked at the SEC's discretion.
#
# Copy this file to .env (which is gitignored) and edit the values below.
# ---------------------------------------------------------------------------

# REQUIRED — must include an app identifier and a real reachable email.
# Example: "sec-edgar-mcp/0.1.0 (your.name@example.com)"
#
# IMPORTANT: SEC EDGAR fair-use policy REQUIRES a real, reachable email
# address. Do NOT use noreply / unreachable emails (e.g. *.users.noreply.github.com)
# — SEC will deny-list your IP within 24 hours and return 403 with HTML
# "Your Request Originates from an Undeclared Automated Tool".
# Format: "<App Name> (<real-contact-email>)"
SEC_EDGAR_USER_AGENT=

# OPTIONAL — override the SEC fair-use rate limit (max 10 req/s per SEC ToS).
# Token-bucket throttle in src/sec_edgar_mcp/client.py defaults to 8 req/s
# to leave headroom for the burst smoothing the bucket performs.
SEC_EDGAR_RATE_LIMIT_PER_SEC=8

# OPTIONAL — DuckDB cache toggles (default: enabled).
SEC_EDGAR_CACHE_ENABLED=1
SEC_EDGAR_CACHE_BYPASS=0

# OPTIONAL — log level (default: WARNING).
LOG_LEVEL=WARNING
